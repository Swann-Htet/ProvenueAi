# ProvenueAI — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit your real .env to git.

# ── MySQL ──────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword_change_me
MYSQL_USER=provenue
MYSQL_PASSWORD=provenue_pass_change_me

# ── Auth ───────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret
ADMIN_EMAIL=admin@provenue.ai
ADMIN_PASSWORD=Provenue@2026

# ── NVIDIA NIM ─────────────────────────────────────────────────────────────
NIM_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL=meta/llama-3.1-8b-instruct

# ── Optional ───────────────────────────────────────────────────────────────
SERPER_API_KEY=
LIVE_GEO=0

# ── Ports ──────────────────────────────────────────────────────────────────
FRONTEND_PORT=80
